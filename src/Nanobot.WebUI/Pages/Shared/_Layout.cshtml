<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nanobot WebUI</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <div class="nav-brand">
                <span class="logo">🐈</span>
                <span class="title">Nanobot</span>
            </div>
            <div class="nav-links">
                <a href="/">Chat</a>
                <a href="/settings">Settings</a>
            </div>
        </nav>
    </header>
    
    <main>
        @RenderBody()
    </main>
    
    <footer>
        <p>Nanobot WebUI - .NET 10 | <a href="https://github.com/santoshbhor/nanobot4net">GitHub</a></p>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>